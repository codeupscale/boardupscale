# =================================================================
# Boardupscale — Production Environment Variables
# Copy this file to .env and fill in every value marked REQUIRED
# setup.sh fills these automatically — only edit if running manually
# =================================================================

# --- Domain (REQUIRED) ---
# Your server's domain, e.g. api.mycompany.com
DOMAIN=REPLACE_DOMAIN

# --- PostgreSQL (REQUIRED) ---
POSTGRES_DB=boardupscale
POSTGRES_USER=boardupscale
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DATABASE_URL=postgresql://boardupscale:CHANGE_THIS_STRONG_PASSWORD@postgres:5432/boardupscale

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- Elasticsearch ---
ELASTICSEARCH_URL=http://elasticsearch:9200

# --- MinIO — local file storage (REQUIRED) ---
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=CHANGE_THIS_MINIO_ACCESS_KEY
MINIO_SECRET_KEY=CHANGE_THIS_MINIO_SECRET_KEY
MINIO_BUCKET=boardupscale

# --- JWT (REQUIRED — use long random strings, min 32 chars each) ---
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_THIS_LONG_RANDOM_SECRET_32_CHARS_MIN
JWT_REFRESH_SECRET=CHANGE_THIS_ANOTHER_LONG_RANDOM_SECRET
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- SMTP (REQUIRED) ---
# Recommended: AWS SES
#   Host: email-smtp.<region>.amazonaws.com
#   Port: 587
#   User/Pass: create SMTP credentials in SES console
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=YOUR_SES_SMTP_USERNAME
SMTP_PASS=YOUR_SES_SMTP_PASSWORD
SMTP_FROM=noreply@REPLACE_DOMAIN

# --- Frontend (REQUIRED — set after Amplify deployment) ---
# Your Amplify app URL, e.g. https://main.d1abc.amplifyapp.com
# Or your custom domain, e.g. https://app.mycompany.com
# Comma-separate multiple origins if needed
FRONTEND_URL=https://REPLACE_WITH_AMPLIFY_URL
CORS_ORIGIN=https://REPLACE_WITH_AMPLIFY_URL

# --- App ---
NODE_ENV=production
PORT=4000

# --- OAuth (optional — leave empty to disable) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://REPLACE_DOMAIN/api/auth/google/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://REPLACE_DOMAIN/api/auth/github/callback

# --- AI Features (optional) ---
AI_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
AI_MAX_TOKENS_PER_ORG_PER_DAY=100000

# --- SAML SSO (optional) ---
SAML_ENTRY_POINT=
SAML_ISSUER=boardupscale
SAML_CERT=
SAML_CALLBACK_URL=https://REPLACE_DOMAIN/api/auth/saml/callback

# --- Stripe Billing (optional) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# --- GitHub Integration (optional) ---
GITHUB_APP_WEBHOOK_SECRET=
