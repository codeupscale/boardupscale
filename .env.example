# =============================================================================
#  Boardupscale — Environment Variable Reference
# =============================================================================
#
#  Copy this file to .env and fill in the required values before starting:
#
#    cp .env.example .env
#
#  [REQUIRED] — must be set before running
#  [OPTIONAL] — safe defaults; leave blank to disable the feature
#
# =============================================================================


# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------

# Node environment. Use "production" in deployed environments.
NODE_ENV=development

# Port the NestJS API listens on inside the container.
PORT=4000

# Public URL of the frontend — used in email links, OAuth redirects, and CORS.
# Vite dev (`services/web`) runs on port 3000; Docker/nginx stack uses 8091.
FRONTEND_URL=http://localhost:3000

# Allowed CORS origins. Must match FRONTEND_URL in production.
CORS_ORIGIN=http://localhost:3000


# -----------------------------------------------------------------------------
# DATABASE  [REQUIRED]
# -----------------------------------------------------------------------------

# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
#
# Docker Compose (API in container → bundled `postgres` service):
# DATABASE_URL=postgresql://boardupscale:boardupscale@postgres:5432/boardupscale
#
# Local API on host + existing Copilot Postgres (`copilot-postgres` → host :5433):
DATABASE_URL=postgresql://copilot:copilot@localhost:5433/boardupscale


# -----------------------------------------------------------------------------
# REDIS  [REQUIRED]
# -----------------------------------------------------------------------------

# Docker Compose: redis://redis:6379
# Copilot Redis (`copilot-redis` → host :6380):
REDIS_URL=redis://localhost:6380


# -----------------------------------------------------------------------------
# ELASTICSEARCH  [OPTIONAL]
# -----------------------------------------------------------------------------

# Leave unset for local dev without Elasticsearch — search falls back to PostgreSQL.
# Docker Compose: http://elasticsearch:9200
# ELASTICSEARCH_URL=


# -----------------------------------------------------------------------------
# FILE STORAGE — MinIO / AWS S3  [REQUIRED]
# -----------------------------------------------------------------------------

# Copilot MinIO (`copilot-minio` → API :9000, console :8900):
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false

# ⚠  Change these before deploying to production.
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

MINIO_BUCKET=boardupscale


# -----------------------------------------------------------------------------
# JWT AUTHENTICATION  [REQUIRED]
# -----------------------------------------------------------------------------

# ⚠  MUST be changed to a long random string before deploying.
# Generate a secure value: openssl rand -base64 64
JWT_SECRET=change-this-to-a-long-random-secret-before-deploying

# Access token lifetime — keep short for security.
JWT_EXPIRY=15m

# Refresh token lifetime.
JWT_REFRESH_EXPIRY=7d


# -----------------------------------------------------------------------------
# EMAIL / SMTP  [REQUIRED]
# -----------------------------------------------------------------------------

# Copilot Mailpit (`copilot-mailpit` → SMTP :1025, UI :8025):
# For production use a real provider (AWS SES, SendGrid, Postmark, etc.).
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@boardupscale.local

# Uncomment for authenticated SMTP (production):
# SMTP_USER=
# SMTP_PASS=
# SMTP_SECURE=true   # true = TLS on port 465


# -----------------------------------------------------------------------------
# OAUTH — GOOGLE  [OPTIONAL]
# -----------------------------------------------------------------------------
# Enables "Sign in with Google".
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback


# -----------------------------------------------------------------------------
# OAUTH — GITHUB  [OPTIONAL]
# -----------------------------------------------------------------------------
# Enables "Sign in with GitHub".
# Create an OAuth App at: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:4000/api/auth/github/callback


# -----------------------------------------------------------------------------
# SAML 2.0 SSO  [OPTIONAL]
# -----------------------------------------------------------------------------
# Enables enterprise SSO via SAML (Okta, Azure AD, OneLogin, etc.).
SAML_ENTRY_POINT=
SAML_ISSUER=boardupscale
SAML_CERT=
SAML_CALLBACK_URL=http://localhost:4000/api/auth/saml/callback


# -----------------------------------------------------------------------------
# AI FEATURES  [OPTIONAL]
# -----------------------------------------------------------------------------
# GPT-powered issue summaries and semantic search. Disabled by default.
AI_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Daily token budget per organisation — acts as a cost guardrail.
AI_MAX_TOKENS_PER_ORG_PER_DAY=100000


# -----------------------------------------------------------------------------
# BILLING — STRIPE  [OPTIONAL]
# -----------------------------------------------------------------------------
# Leave blank to run without billing (all features unlocked for self-hosters).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=


# -----------------------------------------------------------------------------
# GITHUB INTEGRATION  [OPTIONAL]
# -----------------------------------------------------------------------------
# Enables linking commits and pull requests to Boardupscale issues.
# Set a random secret and use it when configuring your GitHub webhook.
GITHUB_APP_WEBHOOK_SECRET=


# -----------------------------------------------------------------------------
# ENTERPRISE  [OPTIONAL]
# -----------------------------------------------------------------------------
# Set to true if you hold a Boardupscale Enterprise licence.
# Unlocks SAML SSO enforcement, extended audit retention, and priority support.
# Community Edition: leave as false — all core features remain fully available.
ENTERPRISE_ENABLED=false


# -----------------------------------------------------------------------------
# JIRA IMPORT  [REQUIRED for Jira import feature]
# -----------------------------------------------------------------------------
# AES-256-GCM key used to encrypt Jira API tokens at rest in jira_connections.
# Must match between API and Worker services. Change this before deploying.
# Generate a secure value: openssl rand -base64 32
APP_SECRET=change-this-to-a-long-random-secret-before-deploying


# -----------------------------------------------------------------------------
# TELEMETRY  [OPTIONAL]
# -----------------------------------------------------------------------------
# Boardupscale sends a single anonymous ping on startup to help us understand
# adoption. No PII is ever collected — only: anonymous installation ID,
# version, platform, org count, active user count.
# Set to false to opt out completely.
TELEMETRY_ENABLED=true
